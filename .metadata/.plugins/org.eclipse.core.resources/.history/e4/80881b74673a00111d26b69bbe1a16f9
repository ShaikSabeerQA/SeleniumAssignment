package pages;

import org.openqa.selenium.*;
import org.openqa.selenium.support.*;

import utils.WaitUtil;

public class KSRTCLoginPage {

    WebDriver driver;
    WaitUtil waitUtil;

    public KSRTCLoginPage(WebDriver driver) {
        this.driver = driver;
        PageFactory.initElements(driver, this);
        waitUtil = new WaitUtil(driver);
        
    }

    @FindBy(xpath = "//div[@class='header-right-item-text'][contains(text(),'Commuter')]")
    WebElement signIn;

    @FindBy(xpath = "//label[text() = 'Email ID']")
    WebElement emailid;

    @FindBy(id = "password")
    WebElement password;

    @FindBy(xpath = "//button[text()='Login']")
    WebElement loginBtn;

    @FindBy(xpath = "//div[contains(text(),'Login incorrect')]")
    WebElement loginError;

    @FindBy(linkText = "Forgot Password?")
    WebElement forgotPwd;

    @FindBy(id = "email")
    WebElement email;

    @FindBy(xpath = "//button[text()='Submit']")
    WebElement submitBtn;

    @FindBy(xpath = "//div[contains(text(),'Login Name not found')]")
    WebElement forgotError;

    // ✅ Phone number validation
    @FindBy(xpath = "//*[contains(text(),'080-26252625')]")
    WebElement phoneNumber;

    // Actions
    public boolean isPhoneDisplayed() {
        return phoneNumber.isDisplayed();
    }

    public void clickSignIn() {
    	waitUtil.clickWithWait(signIn);
        signIn.click();
        
    }
-
    public void login(String user, String pass) {
	 emailid.sendKeys(user);
        password.sendKeys(pass);
        loginBtn.click();
    }

    public String getLoginError() {
        return loginError.getText();
    }

    public void clickForgotPassword() {
        forgotPwd.click();
    }

    public void submitEmail(String mail) {
        email.sendKeys(mail);
        submitBtn.click();
    }

    public String getForgotError() {
        return forgotError.getText();
    }
}